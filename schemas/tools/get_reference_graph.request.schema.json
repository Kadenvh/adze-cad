{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adze.dev/schemas/tools/get_reference_graph.request.schema.json",
  "title": "get_reference_graph request",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool_name", "action_class", "parameters"],
  "properties": {
    "tool_name": { "const": "get_reference_graph" },
    "action_class": { "const": "green" },
    "parameters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "depth": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4,
          "default": 1
        },
        "include_external_references": {
          "type": "boolean",
          "default": true
        }
      }
    }
  }
}
