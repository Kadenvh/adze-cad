{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adze.dev/schemas/traces/recipe-candidate.schema.json",
  "title": "Recipe candidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "recipe_id",
    "title",
    "intent",
    "source_trace_ids",
    "tool_sequence",
    "promotion_state",
    "reliability_score"
  ],
  "properties": {
    "recipe_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "intent": { "type": "string", "minLength": 1 },
    "source_trace_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "tool_sequence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "promotion_state": {
      "type": "string",
      "enum": ["candidate", "reviewed", "promoted", "rejected"]
    },
    "reliability_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "required_unlock_tier": {
      "type": "string",
      "enum": ["baseline", "assisted", "reviewed", "trusted"]
    },
    "review_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
