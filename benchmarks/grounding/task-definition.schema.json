{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sw-plugin.local/benchmarks/grounding/task-definition.schema.json",
  "title": "Grounding task definition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "corpus_source_id",
    "description",
    "document_type",
    "question",
    "expected_tool",
    "expected_assertions",
    "status"
  ],
  "properties": {
    "task_id": { "type": "string", "minLength": 1 },
    "corpus_source_id": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "document_type": {
      "type": "string",
      "enum": ["part", "assembly", "drawing", "reference_data"]
    },
    "entry_path": {
      "type": ["string", "null"]
    },
    "question": { "type": "string", "minLength": 1 },
    "expected_tool": { "type": "string", "minLength": 1 },
    "expected_assertions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready_for_curation", "ready_for_eval"]
    }
  }
}
